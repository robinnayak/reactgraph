{
  "name": "reactgraph",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build && npm run sync-viewer-assets",
    "dev": "turbo run dev",
    "analyze": "node packages/core/dist/cli.js",
    "sync-viewer-assets": "node packages/core/scripts/copy-viewer-assets.cjs",
    "view": "node scripts/view-graph.mjs",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
