{
  "name": "reactgraph-vscode",
  "publisher": "reactgraph",
  "displayName": "ReactGraph",
  "description": "Visualize your React/Next.js component hierarchy, hooks, and API connections",
  "version": "0.1.4",
  "private": true,
  "main": "dist/extension.js",
  "icon": "assets/icon.png",
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "react",
    "nextjs",
    "graph",
    "components",
    "visualization",
    "hierarchy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/robinnayak/reactgraph"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "activationEvents": [
    "onCommand:reactgraph.openGraph"
  ],
  "contributes": {
    "commands": [
      {
        "command": "reactgraph.openGraph",
        "title": "ReactGraph: Open Graph"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "reactgraph.openGraph"
        }
      ]
    }
  },
  "scripts": {
    "prebuild": "node scripts/clean-dist.js",
    "build": "esbuild src/extension.ts src/healthCheckWorker.ts --bundle --outdir=dist --external:vscode --external:fsevents --platform=node --target=node18 --format=cjs --minify --tree-shaking=true --legal-comments=none",
    "postbuild": "node scripts/copy-ui.js",
    "dev": "tsc -p tsconfig.json --watch",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@reactgraph-ui/core": "^0.1.2",
    "@types/vscode": "^1.105.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.2"
  }
}