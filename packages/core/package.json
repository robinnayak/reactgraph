{
  "name": "@reactgraph-ui/core",
  "version": "0.1.5",
  "description": "Visualize your React/Next.js project as an interactive hierarchy graph. Maps Pages -> Components -> Hooks -> APIs with props, types, and connections.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "reactgraph": "bin/reactgraph"
  },
  "keywords": [
    "react",
    "nextjs",
    "visualization",
    "graph",
    "components",
    "hooks",
    "developer-tools",
    "ast",
    "typescript"
  ],
  "author": "Robin Nayak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robinnayak/reactgraph"
  },
  "homepage": "https://github.com/robinnayak/reactgraph#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/copy-viewer-assets.cjs",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --pool=threads"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.43.0",
    "@typescript-eslint/typescript-estree": "^8.43.0",
    "commander": "^14.0.1",
    "glob": "^11.0.3"
  }
}
